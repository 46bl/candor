{
  "manifest_version": 3,
  "name": "CANDOR",
  "version": "1.0.0",
  "description": "Know before you buy. Honest review aggregation from Amazon, Reddit, Trustpilot, and web. No tracking. No cookies. No data stored.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://c4ndor.xyz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CANDOR — Check this product"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.com.au/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.es/*",
        "https://www.amazon.it/*",
        "https://www.amazon.co.jp/*",
        "https://*.etsy.com/listing/*",
        "https://www.bestbuy.com/site/*",
        "https://www.walmart.com/ip/*",
        "https://www.target.com/*",
        "https://www.newegg.com/*",
        "https://www.bhphotovideo.com/*"
      ],
      "js": [
        "compat.js",
        "config.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "compat.js",
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "candor@candor.app",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}