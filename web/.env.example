# ─── AI Provider ─────────────────────────────────────────────────────────────
# Supported: openai | anthropic | ollama | lmstudio | custom
# "openai" also covers Groq and any OpenAI-compatible endpoint via OPENAI_BASE_URL.
AI_PROVIDER=openai

# ─── Groq (recommended — fast, cheap, OpenAI-compatible) ──────────────────────
# Get a free API key at https://console.groq.com
# CANDOR is tuned for llama-3.1-8b-instant via Groq.
OPENAI_API_KEY=gsk_...
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# ─── OpenAI (if you prefer GPT models) ────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Ollama (local, no API key needed) ────────────────────────────────────────
# Start Ollama: `ollama serve` then `ollama pull llama3.2`
# Set AI_PROVIDER=ollama to use these
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ─── LM Studio (local) ────────────────────────────────────────────────────────
# Start LM Studio server, set AI_PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model

# ─── Self-hosted mode ─────────────────────────────────────────────────────────
# Set to true to run without tiers, limits, or account requirements.
# Enables headless operation: no /upgrade page, no daily quotas, no pricing UI.
# Ideal for personal use or deploying for a small trusted group.
SELF_HOSTED=false

# ─── Development ──────────────────────────────────────────────────────────────
# Set to true to use deterministic mock responses (no AI key needed)
USE_MOCK=false

# ─── Review & Article Search ──────────────────────────────────────────────────
# At least one key is STRONGLY recommended in production.
# Without a key, direct scraping is used — datacenter IPs get blocked by Amazon,
# Trustpilot, and DuckDuckGo, meaning zero data is returned for every analysis.
#
# Serper.dev — recommended ($50 / 50k searches). Free trial: https://serper.dev
SERPER_API_KEY=
# Brave Search API — 2,000 free/month. Sign up: https://brave.com/search/api/
BRAVE_API_KEY=
# SerpAPI — alternative: https://serpapi.com
SERPAPI_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
DB_PATH=candor.db

# ─── Stripe (optional — required for paid tiers) ──────────────────────────────
# Leave blank in development — upgrade page will auto-upgrade accounts for testing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
